# PostgreSQL connection (copy to .env and fill in values)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
# Application database with project tables (postgres DB is empty by default)
DB_NAME=pesto_db
DB_ECHO=false

# Frontend (optional, see frontend/.env.example)
# VITE_API_URL=
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
